{
  "info": {
    "name": "GearUp API",
    "description": "Rent Sports & Outdoor Gear Instantly - Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "customerToken", "value": "" },
    { "key": "providerToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "gearId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "rentalId", "value": "" },
    { "key": "sessionId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Customer\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"01700000000\",\n  \"role\": \"CUSTOMER\"\n}"
            }
          }
        },
        {
          "name": "Register Provider",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Trail Rentals\",\n  \"email\": \"trail@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"PROVIDER\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Gear (Public)",
      "item": [
        {
          "name": "Get All Gear",
          "request": { "method": "GET", "url": "{{baseUrl}}/gear?page=1&limit=10" }
        },
        {
          "name": "Get Gear By ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/gear/{{gearId}}" }
        },
        {
          "name": "Get Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        }
      ]
    },
    {
      "name": "Provider",
      "item": [
        {
          "name": "Add Gear",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": "{{baseUrl}}/provider/gear",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Trek Mountain Bike\",\n  \"description\": \"Full-suspension mountain bike for rough trails.\",\n  \"brand\": \"Trek\",\n  \"pricePerDay\": 25,\n  \"images\": [\"https://example.com/bike.jpg\"],\n  \"stock\": 5,\n  \"categoryId\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Gear",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": "{{baseUrl}}/provider/gear"
          }
        },
        {
          "name": "Update Gear",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": "{{baseUrl}}/provider/gear/{{gearId}}",
            "body": { "mode": "raw", "raw": "{\n  \"pricePerDay\": 30\n}" }
          }
        },
        {
          "name": "Delete Gear",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": "{{baseUrl}}/provider/gear/{{gearId}}"
          }
        },
        {
          "name": "Get Provider Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{providerToken}}" }],
            "url": "{{baseUrl}}/provider/orders"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{providerToken}}" }
            ],
            "url": "{{baseUrl}}/provider/orders/{{rentalId}}",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CONFIRMED\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Rentals",
      "item": [
        {
          "name": "Create Rental Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/rentals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDate\": \"2026-08-01\",\n  \"endDate\": \"2026-08-05\",\n  \"items\": [\n    { \"gearItemId\": \"{{gearId}}\", \"quantity\": 1 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get My Rentals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/rentals"
          }
        },
        {
          "name": "Get Rental By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/rentals/{{rentalId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment (Stripe Checkout)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/payments/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalOrderId\": \"{{rentalId}}\"\n}"
            }
          }
        },
        {
          "name": "Confirm Payment (manual, after paying in Stripe checkout)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/payments/confirm",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/payments"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gearItemId\": \"{{gearId}}\",\n  \"rating\": 5,\n  \"comment\": \"Great gear, worked perfectly!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/users/:id",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"SUSPENDED\"\n}" }
          }
        },
        {
          "name": "Get All Gear (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/gear"
          }
        },
        {
          "name": "Get All Rentals (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/rentals"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Water Sports\",\n  \"description\": \"Kayaks, paddleboards, diving gear\"\n}"
            }
          }
        }
      ]
    }
  ]
}
